{
  "name": "terraria-checklist-react",
  "version": "1.0.0",
  "description": "A client-side Terraria progression checklist made with React and TypeScript.",
  "main": "main.tsx",
  "scripts": {
    "start": "webpack-dev-server --mode development --open --hot",
    "build": "rm -fr dist && webpack --mode production && rm -f dist/bundle.js.LICENSE.txt && npm run format",
    "reset": "rm -fr .node_modules dist package-lock.json && npm cache clean --force && npm install",
    "lint": "eslint '**/*.{ts,js,tsx}'",
    "format": "prettier --config .prettierrc {dist,src}/*.html --write"
  },
  "author": "https://github.com/ewauq",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.20.7",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@types/react-dom": "^18.0.10",
    "@types/react": "^18.0.26",
    "@types/styled-components": "^5.1.26",
    "babel-loader": "^9.1.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.3",
    "eslint-import-resolver-typescript": "^3.5.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-unicorn": "^45.0.2",
    "eslint": "^8.31.0",
    "html-react-parser": "^3.0.7",
    "html-webpack-plugin": "^5.5.0",
    "html-webpack-tags-plugin": "^3.0.2",
    "normalize.css": "^8.0.1",
    "prettier": "^2.8.1",
    "react-dom": "^18.2.0",
    "react": "^18.2.0",
    "style-loader": "^3.3.1",
    "styled-components": "^5.3.6",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.4",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.11.1",
    "webpack": "^5.75.0"
  }
}
